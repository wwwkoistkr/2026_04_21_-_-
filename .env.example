# 🔐 일일 브리핑 시스템 환경 변수 예시 파일
# 이 파일을 .env 로 복사한 뒤 실제 값을 채워 사용하세요.
# (.env 는 .gitignore 로 이미 제외되어 있습니다.)

# ── 필수 ────────────────────────────────────────────────
# Google AI Studio (https://aistudio.google.com) 에서 발급
GEMINI_API_KEY=paste-your-gemini-key-here

# 발송 Gmail 계정
EMAIL_SENDER=you@gmail.com

# Gmail "앱 비밀번호" 16자
#  1) Google 계정 → 보안 → 2단계 인증 ON
#  2) 2단계 인증 하단의 '앱 비밀번호' 에서 생성
EMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# 받는 사람 (쉼표로 여러 개 가능). 생략 시 EMAIL_SENDER 본인에게 발송.
EMAIL_RECIPIENTS=me@gmail.com,partner@gmail.com

# ── 선택 ────────────────────────────────────────────────
# Google Cloud Console → YouTube Data API v3 에서 API 키 발급
# 미설정 시 채널 RSS Fallback 으로 자동 전환 (무료, 무설정)
YOUTUBE_API_KEY=

# 디일렉 이외의 채널로 바꾸고 싶다면 여기에 channel_id 지정
THELEC_YOUTUBE_CHANNEL_ID=UC2GRwEADsEKEX5k-Xg9YphA

# DRY_RUN=true 로 설정하면 메일은 발송하지 않고 HTML 프리뷰만 저장
DRY_RUN=false
